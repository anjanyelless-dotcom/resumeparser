# Backend Environment Variables - Example Configuration
PORT=3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/resume_parser
JWT_SECRET=your_super_secret_key_change_this_in_production
REDIS_URL=redis://localhost:6379
AI_SERVICE_URL=http://localhost:8001
FILE_UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=10
NODE_ENV=development

# Additional Backend Configuration
SECRET_KEY=your_super_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Storage Configuration
STORAGE_DIR=./storage
UPLOAD_MAX_SIZE_MB=20

# Parsing Configuration
PARSING_MODE=deterministic
LLM_PROVIDER=none

# OCR Configuration
OCR_MIN_TEXT_CHARS=100
OCR_MAX_PAGES=15
PDF_MAX_PAGES=50

# Security
CLAMAV_ENABLED=false

# Logging
LOG_LEVEL=INFO

# External Search Configuration
# Feature flag to enable external candidate search (LinkedIn via Google CSE, GitHub)
ENABLE_EXTERNAL_SEARCH=false

# Minimum internal results before triggering external search fallback
MIN_INTERNAL_RESULTS=5

# Google Custom Search API for LinkedIn X-Ray search
# Get your API key and CSE ID from: https://developers.google.com/custom-search/v1/overview
GOOGLE_CSE_API_KEY=your_google_cse_api_key
GOOGLE_CSE_ID=your_google_custom_search_engine_id

# GitHub Personal Access Token for GitHub user search
# Get your token from: https://github.com/settings/tokens (requires public_repo scope)
GITHUB_TOKEN=your_github_personal_access_token

# GeoNames API for location detection
# Get your free username from: https://www.geonames.org/login
GEONAMES_USERNAME=your_geonames_username
