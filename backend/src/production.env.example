# Backend Production Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=production

# Database Configuration (PostgreSQL)
# Option 1: Use DATABASE_URL (recommended for Docker)
DATABASE_URL=postgresql://resume_parser:your_secure_password@postgres:5432/resume_parser

# Option 2: Individual database parameters (alternative)
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=resume_parser
# DB_USER=resume_parser
# DB_PASSWORD=your_secure_password

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_change_this_in_production_min_32_chars

# AI Service Configuration
AI_SERVICE_URL=http://ai-service:8000

# File Upload Configuration
FILE_UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=10
UPLOAD_MAX_SIZE_MB=10

# LLM Configuration
LLM_PROVIDER=gemini
OPENAI_API_KEY=your_openai_api_key_if_using_openai

# PM2 Configuration (for non-Docker deployment)
PM2_PUBLIC_KEY=
PM2_SECRET_KEY=