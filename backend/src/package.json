{
  "name": "resume-parser-backend-src",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript database utilities for Resume Parser",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "db:reset": "npx ts-node scripts/reset_db.ts",
    "db:setup": "npx ts-node scripts/run_setup.ts",
    "db:migrate": "npx ts-node scripts/apply_all_migrations.ts",
    "db:init": "npm run db:reset && npm run db:setup && npm run db:migrate",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-validator": "^7.3.1",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "openai": "^6.42.0",
    "pg": "^8.12.0",
    "socket.io": "^4.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@types/socket.io": "^3.0.1",
    "@types/uuid": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
