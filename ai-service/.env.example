# AI Service Environment Variables - Example Configuration
MODEL_NAME=dslim/bert-base-NER
MODEL_CACHE_DIR=./models/cache
MAX_RESUME_LENGTH=5000
CONFIDENCE_THRESHOLD=0.80
PORT=8001

# Additional AI Service Configuration
HOST=0.0.0.0
DEBUG=false
LOG_LEVEL=INFO

# Model Configuration
DEVICE=cpu
BATCH_SIZE=16
MAX_SEQUENCE_LENGTH=512

# API Configuration
API_PREFIX=/api/v1
DOCS_URL=/docs
RELOAD=false

# Performance
WORKERS=1
TIMEOUT=30

# LLM API Keys for Experience Extraction
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=

# AWS Textract (OCR + Table extraction for scanned/table-format PDFs)
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_DEFAULT_REGION=us-east-1
