# AI Service Production Environment Variables

# Server Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=false
LOG_LEVEL=INFO

# Model Configuration (Memory Optimized for 2GB RAM)
MODEL_NAME=dslim/bert-base-NER
MODEL_CACHE_DIR=/app/models/cache
MAX_RESUME_LENGTH=5000
CONFIDENCE_THRESHOLD=0.80
DEVICE=cpu
BATCH_SIZE=8
MAX_SEQUENCE_LENGTH=512
DEBERTA_MODEL_PATH=/app/models/cache

# API Configuration
API_PREFIX=/api/v1
DOCS_URL=/docs
RELOAD=false

# Performance Settings (Critical for 2GB RAM)
WORKERS=1
TIMEOUT=120

# LLM API Keys (Required for experience extraction)
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration (for training/data export)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=resume_parser
DB_USER=resume_parser
DB_PASSWORD=your_secure_password

# Memory Optimization Settings
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
TOKENIZERS_PARALLELISM=false
TRANSFORMERS_CACHE=/app/models/cache
HF_HOME=/app/models/cache